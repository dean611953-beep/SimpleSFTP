<Window x:Class="SimpleFTP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleFTP - Windows FTP Server"
        Height="750" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📂 SimpleFTP" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="0" Margin="0,30,0,0" Foreground="#666">
            <TextBlock Text="让Windows电脑变成一个FTP接收服务器 "/>
            <Run FontSize="12"/>
        </TextBlock>

        <!-- Configuration Section -->
        <GroupBox Grid.Row="1" Header="⚙️ 配置" Margin="0,5">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Port -->
                    <Label Grid.Row="0" Grid.Column="0" Content="端口:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="PortBox" Text="21" Margin="0,0,10,0"/>

                    <!-- Username -->
                    <Label Grid.Row="0" Grid.Column="2" Content="用户名:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Row="0" Grid.Column="3" x:Name="UserBox" Margin="0,0,10,0"/>

                    <!-- Password -->
                    <Label Grid.Row="1" Grid.Column="0" Content="密码:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PassBox" Margin="0,0,10,0"/>

                    <!-- Root Directory -->
                    <Label Grid.Row="1" Grid.Column="2" Content="保存目录:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Grid Grid.Row="1" Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="DirBox" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" x:Name="BrowseBtn" Content="..." Width="30" Click="BrowseBtn_Click"/>
                    </Grid>
                </Grid>

                <!-- IP Info -->
                <TextBlock x:Name="IpInfo" Margin="0,5,0,0" Foreground="#4CAF50" FontSize="12"/>
            </StackPanel>
        </GroupBox>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <Button x:Name="StartBtn" Content="▶ 启动" Width="100" Height="35"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    Click="StartBtn_Click" Margin="0,0,10,0"/>
            <Button x:Name="StopBtn" Content="⏹ 停止" Width="100" Height="35"
                    Background="#F44336" Foreground="White" FontWeight="Bold"
                    Click="StopBtn_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="RefreshBtn" Content="🔄 刷新列表" Width="120" Height="35"
                    Click="RefreshBtn_Click"/>
        </StackPanel>

        <!-- Upload Log & File List -->
        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Log Panel -->
            <GroupBox Grid.Column="0" Header="📋 日志" Margin="0,0,5,0">
                <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11" Background="#FFF"
                         TextWrapping="NoWrap"/>
            </GroupBox>

            <!-- File List Panel -->
            <GroupBox Grid.Column="1" Header="📁 上传文件" Margin="5,0,0,0">
                <ListBox x:Name="FileList" Background="#FFF" FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5,2">
                                <TextBlock Text="{Binding FileName}" FontWeight="Medium"/>
                                <TextBlock FontSize="10" Foreground="#666">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F1} KB | {1:yyyy-MM-dd HH:mm:ss} | {2}">
                                            <Binding Path="Size"/>
                                            <Binding Path="UploadedAt"/>
                                            <Binding Path="IpAddress"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <!-- Stats Footer -->
        <Border Grid.Row="4" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 总上传: " FontWeight="Bold"/>
                <TextBlock x:Name="TotalBytesText" Text="0 B"/>
                <TextBlock Text="  |  " Margin="10,0"/>
                <TextBlock Text="📁 文件数: " FontWeight="Bold"/>
                <TextBlock x:Name="FileCountText" Text="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
