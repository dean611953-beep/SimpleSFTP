<Window x:Class="SimpleFTP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleFTP - 轻量FTP服务端" 
        Height="600" Width="950"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== 顶部控制栏 ========== -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,8">
                <Button Content="▶ 启动" x:Name="BtnStart" Click="BtnStart_Click"
                        Style="{StaticResource PrimaryButton}" Width="80" Padding="8,4"/>
                <Button Content="⏹ 停止" x:Name="BtnStop" Click="BtnStop_Click"
                        Margin="8,0,0,0" Width="80" Background="#D13438" Foreground="White" Padding="8,4"
                        BorderThickness="0" IsEnabled="False"/>
                
                <Separator Width="1" Margin="16,0,12,0"/>
                
                <!-- 配置 -->
                <TextBlock Text="端口: " VerticalAlignment="Center" FontSize="13" Fore="#555"/>
                <TextBox x:Name="TxtPort" Width="70" Margin="4,0" Padding="6,4"
                         FontSize="13" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1" Text="21"/>
                
                <TextBlock Text="用户: " VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13" Fore="#555"/>
                <TextBox x:Name="TxtUsername" Width="100" Margin="4,0" Padding="6,4"
                         FontSize="13" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                
                <TextBlock Text="密码: " VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13" Fore="#555"/>
                <TextBox x:Name="TxtPassword" Width="120" Margin="4,0" Padding="6,4"
                         FontSize="13" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                         PreviewKeyDown="TxtPassword_PreviewKeyDown"/>
                
                <Separator Width="1" Margin="12,0,12,0"/>
                
                <!-- 保存目录 -->
                <TextBlock Text="📥 保存至: " VerticalAlignment="Center" FontSize="13" Fore="#555"/>
                <TextBox x:Name="TxtRootDir" Width="300" Margin="4,0" Padding="6,4"
                         FontSize="12" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"/>
                <Button Content="浏览..." Click="BtnBrowseDir_Click" Margin="4,0,0,0" Width="65"
                        Padding="4,4" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ========== 中间内容区 ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：服务器状态 -->
            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="服务器状态" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="14"/>
                    
                    <!-- 状态指示 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="状态:" FontSize="12" Fore="#666" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="ElStatusDot" Width="10" Height="10" Fill="#CCCCCC" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtStatus" Text="已停止" FontSize="12" Fore="#333"/>
                        </StackPanel>
                    </Grid>

                    <!-- IP -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IP:" FontSize="12" Fore="#666"/>
                        <TextBlock Grid.Column="1" x:Name="TxtIp" Text="-" FontSize="12" Fore="#333"/>
                    </Grid>

                    <!-- 连接数 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="连接数:" FontSize="12" Fore="#666"/>
                        <TextBlock Grid.Column="1" x:Name="TxtConnections" Text="0" FontSize="12" Fore="#333"/>
                    </Grid>

                    <!-- 总上传量 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="总上传:" FontSize="12" Fore="#666"/>
                        <TextBlock Grid.Column="1" x:Name="TxtTotalUpload" Text="0 B" FontSize="12" Fore="#333"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- 连接历史 -->
                    <TextBlock Text="📊 上传统计" FontWeight="SemiBold" Margin="0,12,0,8" FontSize="13"/>
                    
                    <TextBlock x:Name="TxtUploadStats" FontSize="12" Fore="#555"
                               Text="暂无上传记录" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 右侧：上传文件列表 -->
            <Grid Grid.Column="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 路径栏 -->
                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥 本地接收目录: " FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock Text="{Binding RootDirText, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="13" Fore="#333"/>
                    </StackPanel>
                </Border>

                <!-- 文件列表 -->
                <ListBox x:Name="lstUploadedFiles" Grid.Row="1"
                         Background="White" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*" MinWidth="150"/>
                                    <ColumnDefinition Width="80" MaxWidth="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 图标 -->
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="14" Text="📄"/>
                                
                                <!-- 文件名 -->
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" 
                                           Text="{Binding FileName}" FontSize="12" Fore="#1A1A1A"
                                           TextTrimming="CharacterEllipsis"/>
                                
                                <!-- 大小 -->
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" 
                                           Text="{Binding FormattedSize}" FontSize="11" Fore="#666"
                                           TextAlignment="Right"/>
                                
                                <!-- 上传时间 -->
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" 
                                           Text="{Binding UploadedAtStr}" FontSize="11" Fore="#999"/>
                                
                                <!-- 用户 -->
                                <TextBlock Grid.Column="4" VerticalAlignment="Center" 
                                           Text="{Binding UserDisplay}" FontSize="11" Fore="#777"/>
                                
                                <!-- 来源IP -->
                                <TextBlock Grid.Column="5" VerticalAlignment="Center" 
                                           Text="{Binding IpDisplay}" FontSize="11" Fore="#999"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    
                    <!-- 空状态 -->
                    <ListBoxItem IsHitTestVisible="False">
                        <TextBlock Text="启动FTP服务后，上传的文件将显示在这里" FontSize="13" Fore="#BBBBBB"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"/>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Grid>

        <!-- ========== 底部日志区 ========== -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 分隔线 -->
            <Line Grid.Row="0" X1="0" Y1="0" X2="1" Y2="0" Stroke="#D0D0D0" StrokeThickness="1"/>
            
            <!-- 日志面板 -->
            <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                    Padding="0,0,0,0">
                <DockPanel Margin="12,8">
                    <TextBlock DockPanel.Dock="Top" Text="📋 日志" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <ScrollViewer x:Name="scrLog" VerticalScrollBarVisibility="Auto" MaxHeight="150" Height="100">
                        <TextBlock x:Name="TxtLog" FontFamily="Consolas, 'Courier New'" FontSize="11" Fore="#333"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
